{
  "apps": [
    {
      "name": "news-pulse-backend",
      "script": "src/server.js",
      "cwd": "/home/ubuntu/News-Pulse/backend",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "300M",
      "restart_delay": 5000,
      "env": {
        "NODE_ENV": "production",
        "PORT": "4000"
      },
      "log_file": "/home/ubuntu/logs/news-pulse-backend.log",
      "error_file": "/home/ubuntu/logs/news-pulse-backend-error.log",
      "merge_logs": true
    }
  ]
}
